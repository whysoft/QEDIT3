void txt_into_clip( std::string str1, std::string str2 )
{
	std::string strCmd;
	int iCmd;
	WFile fl;

	fl.bind("TMPDATA/11.txt");
	fl.write_str( str1 );

	strCmd = "cat { | xclip -selection clipboard";
	SStrf::sreplstr( strCmd, "{",  fl );
	std::cout << strCmd << std::flush << std::endl; 
	iCmd = WFile::run_exe( strCmd ); 

	strCmd = "cat { | xclip -selection primary";
	SStrf::sreplstr( strCmd, "{",  fl );
	std::cout << strCmd << std::flush << std::endl; 
	iCmd = WFile::run_exe( strCmd ); 

	//strCmd = "python3 intoclip.py";
	//std::cout << strCmd << std::flush << std::endl; 
}



//
void pic_into_clip( std::string str1, std::string str2 )
{
	WFile::Utf8toCh(str1);

	if( str1 == "" ) str1 = " ";

	SimpPaper sp;
	WFile fl;

	fl.bind( WFile::MkDir2Path("TMPDATA") + "a.bmp");
	 
	SStrf::sucase(str2);

	sp.AttachHZK( gfBINDDATA("ASC16"), str2=="F"?gfBINDDATA("HZK16F"):gfBINDDATA("HZK16") );
	sp.m_foreColor = sp.MKRGB( 0x00, 0x2e, 0xe1 );
	sp.Init( str1, 277 );
	sp.SaveBmp( fl );

	std::string strCmd;
	int iCmd;

    strCmd = "xclip -selection clipboard -t image/png {";
	SStrf::sreplstr( strCmd, "{",  fl );
	std::cout << strCmd << std::flush << std::endl; 

	iCmd = WFile::run_exe( strCmd ); 
}



//
void clip_append_to_end( std::string str_pagepathname, std::string str1, std::string str2 ) 
{
	std::string strCmd;
	std::string strOut;
	tbool rc;
		
	strCmd = "xclip -o";
	
	rc = WFile::get_shellpipe_output( strCmd, strOut );	
	std::cout << "shellpipe_rc=" << rc << " output=" << strOut << std::endl;

	if( str1 != "" ) str1 += "\r\n";
	str1 += strOut;

	WFile::Utf8toCh(str1); 

	std::string strDojs = 
		"(function () \n"
		"{ \n"
		"var f2 = \n"
		"function() \n"
		"{ \n" 
		"set_text_main_value( g_js_para, 1 );\n"
		"}; \n"
		"setTimeout( f2, 1 ); \n"
		"})(); \n";

	gp_d_ui_mngr->um_page_paint_update( str_pagepathname, strDojs, str1 ); 
}




//
void clip_insert_to_begin( std::string str_pagepathname, std::string str1, std::string str2 ) 
{
	std::string strCmd;
	std::string strOut;
	tbool rc;
		
	strCmd = "xclip -o";
	
	rc = WFile::get_shellpipe_output( strCmd, strOut );
	std::cout << "shellpipe_rc=" << rc << " output=" << strOut << std::endl;

	if( strOut != "" ) strOut += "\r\n";
	str1 = strOut + str1;

	WFile::Utf8toCh(str1); 

	std::string strDojs = 
		"(function () \n"
		"{ \n"
		"var f2 = \n"
		"function() \n"
		"{ \n" 
		"set_text_main_value( g_js_para, 0 );\n"
		"}; \n"
		"setTimeout( f2, 1 ); \n"
		"})(); \n";

	gp_d_ui_mngr->um_page_paint_update( str_pagepathname, strDojs, str1 ); 
}




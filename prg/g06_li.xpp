void undo_a( std::string str_pagepathname, std::string str1, std::string str2, std::vector< std::string > &vec_text_main_lot )
{
	std::string bs1;
	std::string cs1;

	vec_text_main_lot.insert( vec_text_main_lot.begin(), "" );
	vec_text_main_lot.erase( vec_text_main_lot.end() - 1 );

	bs1 = (*(vec_text_main_lot.rbegin())).c_str();
	 
	WFile::Utf8toCh(bs1); 

	std::string strDojs = 
		"(function () \n"
		"{ \n"
		"var f2 = \n"
		"function() \n"
		"{ \n" 
		"set_text_main_value( g_js_para, 1 );\n"
		"}; \n"
		"setTimeout( f2, 0 ); \n"
		"})(); \n";

	gp_d_ui_mngr->um_page_paint_update( str_pagepathname, strDojs, std::string(bs1) ); 
}



//
void trim_a( std::string str_pagepathname, std::string str1, std::string str2 )
{
	std::vector< std::string > vecLines;  
	std::string strMainText;
 
	SStrf::sreplstr( str1, "\r", " "  );
 
	SStrvs::vsa_imp( str1, std::string("\n"), 1, vecLines ); 

	for(std::vector<std::string>::iterator it=vecLines.begin();it!=vecLines.end();++it)
	{
		SCake ckLine;

		ckLine.lets( *it );
		SStrf::strim(ckLine);
 
		if(*ckLine)
		{
			strMainText += ckLine;

			if(it!=vecLines.end()-1) strMainText += "\r\n";

			std::cout << strMainText << std::endl;
		}
	}

	WFile::Utf8toCh(strMainText); 

	std::string strDojs = 
		"(function () \n"
		"{ \n"
		"var f2 = \n"
		"function() \n"
		"{ \n" 
		"set_text_main_value( g_js_para, 1 );\n"
		"}; \n"
		"setTimeout( f2, 0 ); \n"
		"})(); \n";
	
	gp_d_ui_mngr->um_page_paint_update( str_pagepathname, strDojs, strMainText ); 
}



//
void reverse_a( std::string str_pagepathname, std::string str1, std::string str2 )
{
	WFile::Utf8toCh(str1); 
	WFile::Utf8toCh(str2); 

	std::string sOut;

	if( str2 != "" )
	{
		// 按字串分隔来reverse  
		for( int i = (int)SStrvs::vsa_hm( str1, str2, 1 ) - 1 ; i >= 0; i-- )
		{
			sOut += SStrvs::vsa_get( str1, str2, 1, i );
			sOut += str2;
			sOut += "\r\n";
		}
	}
	else
	{
		// 按每个字来reverse  
		std::vector< std::string > vec1;

		vec1 = gbstr_2_vec(str1);

		std::reverse(vec1.begin(), vec1.end());

		for( int i = 0 ; i < (int)vec1.size(); i++ )
		{
			sOut += vec1[i].c_str();
		}
	}

	std::string strDojs = 
		"(function () \n"
		"{ \n"
		"var f2 = \n"
		"function() \n"
		"{ \n" 
		"set_text_main_value( g_js_para, 1 );\n"
		"}; \n"
		"setTimeout( f2, 0 ); \n"
		"})(); \n";

	gp_d_ui_mngr->um_page_paint_update( str_pagepathname, strDojs, sOut ); 
}





if( str_sub2cmd.find("yyyymmdd.hhmmss") == 0 )
{
	std::string str1;
	std::string str2; 
	std::string sOut;  
	wl::SDte dteNow;

	str1 = str_text_main;
	str2 = str_text_sub;

	SStrf::sreplstr( str1, "\r", ""  );

	WFile::Utf8toCh(str1); 

	dteNow.MakeNow(); 

	if(str1.length()>0) sOut = str1 + "\r\n";
	sOut += dteNow.ReadStringPack().c_str();


	std::string strDojs = 
		"(function () \n"
		"{ \n"
		"var f2 = \n"
		"function() \n"
		"{ \n" 
		"set_text_main_value( g_js_para, 1 );\n"
		"}; \n"
		"setTimeout( f2, 0 ); \n"
		"})(); \n";

	gp_d_ui_mngr->um_page_paint_update( str_pagepathname, strDojs, sOut ); 
}

		

if( str_sub2cmd.find("yyyy-mm-dd") == 0 )
{
	std::string str1;
	std::string str2; 
	std::string sOut;   
	wl::SDte dteNow;
	char sz[99];

	str1 = str_text_main;
	str2 = str_text_sub;

	SStrf::sreplstr( str1, "\r", ""  );

	WFile::Utf8toCh(str1); 

	dteNow.MakeNow(); 

	sprintf( sz, "%d-%02d-%02d", dteNow.m_year,  dteNow.m_mon,  dteNow.m_day );

	if(str1.length()>0) sOut = str1 + "\r\n";
	sOut += sz;


	std::string strDojs = 
		"(function () \n"
		"{ \n"
		"var f2 = \n"
		"function() \n"
		"{ \n" 
		"set_text_main_value( g_js_para, 1 );\n"
		"}; \n"
		"setTimeout( f2, 0 ); \n"
		"})(); \n";

	gp_d_ui_mngr->um_page_paint_update( str_pagepathname, strDojs, sOut ); 
}

		

